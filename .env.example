# ── Google Cloud / BigQuery ────────────────────────────────────────────────
# Path to your GCP service account JSON key file (local dev)
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# Your GCP project ID (e.g. my-dwh-midterm-123456)
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery location
BQ_LOCATION=US

# BigQuery dataset names (will be created by setup_bq.py)
BQ_DATASET_RAW=retail_raw
BQ_DATASET_STAGING=retail_staging
BQ_DATASET_MARTS=retail_marts

# ── Alerting Webhooks ─────────────────────────────────────────────────────
# Discord webhook URL  (Settings → Integrations → Webhooks → Copy URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Slack webhook URL (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ── dbt ───────────────────────────────────────────────────────────────────
DBT_TARGET=dev
